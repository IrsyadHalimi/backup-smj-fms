<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="BubbleLayout">
        <attr name="bl_arrowWidth" format="dimension|reference" />
        <attr name="bl_cornersRadius" format="dimension|reference" />
        <attr name="bl_arrowHeight" format="dimension|reference" />
        <attr name="bl_arrowPosition" format="dimension|reference" />
        <attr name="bl_bubbleColor" format="color|reference" />
        <attr name="bl_strokeWidth" format="dimension|reference" />
        <attr name="bl_strokeColor" format="color|reference" />

        <attr name="bl_arrowDirection" format="enum">
            <enum name="left" value="0" />
            <enum name="right" value="1" />
            <enum name="top" value="2" />
            <enum name="bottom" value="3" />
            <enum name="left_center" value="4"/>
            <enum name="right_center" value="5"/>
            <enum name="top_center" value="6"/>
            <enum name="bottom_center" value="7"/>
            <enum name="top_right" value="8"/>
            <enum name="bottom_right" value="9"/>
        </attr>
    </declare-styleable>

    <declare-styleable name="MaskedEditText">
        <attr name="maskType" format="enum">
            <enum name="date" value="0" />
            <enum name="phone" value="1" />
            <enum name="ssn" value="2" />
            <enum name="currency" value="3" />
            <enum name="custom" value="4" />
            <enum name="static_text" value="5" />
            <enum name="credit_card" value="6" />
            <enum name="date_mm_yyyy" value="7" />
        </attr>
        <attr name="maskPattern" format="string" />
        <attr name="returnPattern" format="string" />
        <attr name="currencyDecimalLimit" format="integer" />
    </declare-styleable>
</resources>
