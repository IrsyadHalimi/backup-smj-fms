                        android:layout_gravity="right"
                        android:paddingLeft="5dp"
                        android:paddingRight="0dp"
                        android:orientation="horizontal"
                        tools:ignore="Suspicious0dp">

                        <TextView
                            android:id="@+id/tv_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="16dp"
                            android:paddingRight="5dp"
                            android:layout_gravity="left"
                            android:layout_marginTop="0dp"
                            android:textColor="@color/black"
                            android:hint="Status"/>

                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:layout_gravity="right"
                        android:paddingLeft="5dp"
                        android:paddingRight="0dp"
                        android:orientation="horizontal"
                        tools:ignore="Suspicious0dp">

                        <TextView
                            android:id="@+id/tv_status_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14dp"
                            android:paddingRight="5dp"
                            android:gravity="right"
                            android:layout_gravity="right"
                            android:layout_marginTop="0dp"
                            android:hint="Status"/>

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="5dp"
                android:layout_margin="0dp"
                android:layout_gravity="end"
                android:gravity="end"
                android:orientation="vertical">
                <ImageView
                    android:id="@+id/iv_up"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginLeft="10dp"
                    android:layout_gravity="center"
                    android:src="@drawable/baseline_arrow_circle_up_24"/>
                <ImageView
                    android:id="@+id/iv_down"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_gravity="center"
                    android:src="@drawable/baseline_expand_circle_down_24"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:visibility="gone"
                android:id="@+id/recycler_detail_fleet_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:layout_marginHorizontal="15dp">

            </androidx.recyclerview.widget.RecyclerView>

            <LinearLayout
                android:visibility="visible"
                android:id="@+id/ll_footer_ritase"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_shadow"
                android:layout_marginHorizontal="15dip"
                android:layout_marginTop="10dip"
                android:paddingVertical="0dp"
                android:orientation="horizontal">
                <LinearLayout
                    android:visibility="visible"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:orientation="vertical"
                    tools:ignore="Suspicious0dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="bottom"
                        android:text="TOTAL ACTUAL"
                        android:textColor="@color/black"
                        android:textSize="18dp"
                        android:textStyle="bold" />

                </LinearLayout>
                <LinearLayout
                    android:visibility="visible"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:orientation="vertical"
                    tools:ignore="Suspicious0dp">
                    <TextView
                        android:id="@+id/tv_total_ritase"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_gravity="center"
                        android:gravity="bottom"
                        android:text="0"
                        android:textColor="@color/black"
                        android:textSize="18dp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>