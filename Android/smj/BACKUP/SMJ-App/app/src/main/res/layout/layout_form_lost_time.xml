<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:shimmer="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/transparent"
    android:layout_gravity="top"
    android:gravity="center">

    <RelativeLayout
        android:id="@+id/rl_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:clipChildren="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_rounded_white"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:gravity="center"
            android:layout_gravity="top"
            android:padding="20dp"
            tools:ignore="MissingConstraints">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="0dp"
                android:layout_gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:gravity="left"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="0dip"
                    android:layout_marginEnd="0dip"
                    android:layout_marginBottom="0dip"
                    android:orientation="horizontal"
                    android:paddingLeft="0dp"
                    android:paddingTop="0dp"
                    android:paddingRight="0dp"
                    android:paddingBottom="0dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="5"
                        android:gravity="left"
                        android:layout_gravity="center_vertical"
                        android:orientation="horizontal"
                        tools:ignore="Suspicious0dp">
                        <TextView
                            android:id="@+id/tv_note_label"
                            android:visibility="visible"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_gravity="center_vertical"
                            android:fontFamily="@font/roboto_regular"
                            android:textStyle="bold"
                            android:textSize="18dp"
                            android:textColor="@color/black"
                            android:text="History Time"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/icon_close"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:layout_gravity="center_vertical"
                        android:orientation="horizontal"
                        tools:ignore="Suspicious0dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center_vertical"
                            android:gravity="right"
                            android:src="@drawable/ic_times"
                            android:textSize="16sp" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent">

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:scrollbars="vertical"
                    android:scrollbarAlwaysDrawVerticalTrack="true"
                    android:paddingTop="20dp"
                    android:paddingBottom="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:visibility="visible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_gravity="center_vertical"
                        android:fontFamily="@font/roboto_regular"
                        android:textStyle="normal"
                        android:textSize="16dp"
                        android:textColor="@color/black"
                        android:text="Lost Time"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/name_shift"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="0dp"
                        android:layout_marginTop="0dp"
                        android:layout_marginEnd="0dp"
                        app:backgroundTint="@color/black"
                        app:boxStrokeColor="@color/black"
                        app:hintTextColor="@color/black"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        android:textCursorDrawable="@color/grey"
                        android:hint="Choice Lost Time">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_lost_time"
                            android:focusable="false"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="0dp"
                            android:drawablePadding="10sp"
                            android:fontFamily="@font/roboto_regular"
                            android:drawableEnd="@drawable/ic_search"
                            android:textStyle="normal"
                            android:inputType="text" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:visibility="gone"
                        android:id="@+id/tv_lost_time_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="left"
                        android:gravity="left"
                        android:textColor="@color/red"
                        android:textSize="16sp"
                        android:text=""
                        tools:ignore="RtlHardcoded" />

                    <!-- Start Prioritas -->
                    <LinearLayout
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:paddingTop="0dp"
                        android:paddingLeft="0dp"
                        android:paddingRight="0dp"
                        android:paddingBottom="0dp"
                        android:orientation="vertical">

                        <TextView
                            android:visibility="visible"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:layout_marginBottom="5dp"
                            android:gravity="center"
                            android:layout_gravity="left"
                            android:fontFamily="@font/roboto_regular"
                            android:textStyle="bold"
                            android:textSize="16dp"
                            android:textColor="@color/black"
                            android:text="Start/Stop"/>

                        <RadioGroup
                            android:id="@+id/et_priority"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_rounded_grey">
                            <RadioButton
                                android:id="@+id/low"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:background="@drawable/radio_button_low"
                                android:gravity="center"
                                android:layout_weight="1"
                                android:paddingTop="0dp"
                                android:paddingBottom="0dp"
                                android:paddingStart="15dp"
                                android:paddingEnd="15dp"
                                android:button="@null"
                                android:checked="false"
                                android:drawableRight="@drawable/ic_ellipse_red"
                                android:drawablePadding="5dp"
                                android:textSize="16dp"
                                android:text="Start Lost Time"/>
                            <RadioButton
                                android:id="@+id/high"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:background="@drawable/radio_button_high"
                                android:gravity="center"
                                android:layout_weight="1"
                                android:paddingTop="0dp"
                                android:paddingBottom="0dp"
                                android:paddingStart="15dp"
                                android:paddingEnd="15dp"
                                android:button="@null"
                                android:checked="false"
                                android:drawableRight="@drawable/ic_ellipse_green"
                                android:drawablePadding="5dp"
                                android:textSize="16dp"
                                android:text="Stop Lost Time"/>
                        </RadioGroup>

                    </LinearLayout>
                    <!-- End Prioritas -->

                    <!-- Start Due Date -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:paddingTop="0dp"
                        android:paddingLeft="0dp"
                        android:paddingRight="0dp"
                        android:paddingBottom="0dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_label_time"
                            android:visibility="visible"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:layout_marginBottom="5dp"
                            android:gravity="center"
                            android:layout_gravity="left"
                            android:fontFamily="@font/roboto_regular"
                            android:textStyle="bold"
                            android:textSize="16dp"
                            android:textColor="@color/black"
                            android:text="Time"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_rounded_grey"
                            android:layout_marginTop="0dp"
                            android:paddingTop="0dp"
                            android:paddingLeft="0dp"
                            android:paddingRight="0dp"
                            android:paddingBottom="0dp"
                            android:orientation="horizontal">
                            <ImageView
                                android:id="@+id/iv_time_start"
                                android:visibility="visible"
                                android:layout_width="50dp"
                                android:layout_height="wrap_content"
                                android:background="@color/grey_light"
                                android:padding="10dp"
                                android:layout_marginTop="0dp"
                                android:layout_marginBottom="0dp"
                                android:gravity="center"
                                android:layout_gravity="center"
                                android:fontFamily="@font/roboto_regular"
                                android:src="@drawable/baseline_access_time_24"/>
                            <TextView
                                android:id="@+id/et_time_start"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="18dp"
                                android:textColor="@color/black"
                                android:layout_gravity="center_vertical"
                                android:gravity="center_vertical"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"/>
                        </LinearLayout>

                        <TextView
                            android:visibility="gone"
                            android:id="@+id/tv_time_start"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="left"
                            android:gravity="left"
                            android:textColor="@color/red"
                            android:textSize="16sp"
                            android:text=""
                            tools:ignore="RtlHardcoded" />

                        <TextView
                            android:visibility="gone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="15dp"
                            android:layout_marginBottom="5dp"
                            android:gravity="center"
                            android:layout_gravity="left"
                            android:fontFamily="@font/roboto_regular"
                            android:textStyle="bold"
                            android:textSize="16dp"
                            android:textColor="@color/black"
                            android:text="Time End"/>

                        <LinearLayout
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_rounded_grey"
                            android:layout_marginTop="0dp"
                            android:paddingTop="0dp"
                            android:paddingLeft="0dp"
                            android:paddingRight="20dp"
                            android:paddingBottom="0dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/iv_time_end"
                                android:layout_width="50dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginTop="0dp"
                                android:layout_marginBottom="0dp"
                                android:background="@color/grey_light"
                                android:fontFamily="@font/roboto_regular"
                                android:gravity="center"
                                android:padding="10dp"
                                android:src="@drawable/baseline_access_time_24"
                                android:visibility="visible" />

                            <TextView
                                android:id="@+id/et_time_end"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="18dp"
                                android:textColor="@color/black"
                                android:layout_gravity="center_vertical"
                                android:gravity="center_vertical"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"/>
                        </LinearLayout>

                        <TextView
                            android:visibility="gone"
                            android:id="@+id/tv_time_end"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="left"
                            android:gravity="left"
                            android:textColor="@color/red"
                            android:textSize="16sp"
                            android:text=""
                            tools:ignore="RtlHardcoded" />

                    </LinearLayout>
                    <!-- End Due Date -->

                    <LinearLayout
                        android:id="@+id/add_lost_time"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:layout_marginTop="20dp"
                        android:layout_marginStart="0dp"
                        android:layout_marginEnd="0dp"
                        android:background="@drawable/bg_rounded_blue">
                        <TextView
                            android:id="@+id/txt_facebook"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:drawableTint="@color/white"
                            android:text="Add History Time"
                            android:textColor="@color/white"
                            android:textSize="16sp"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>