<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:shimmer="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_light"
    android:fitsSystemWindows="true"
    android:layout_gravity="top"
    android:gravity="center"
    tools:context=".ui.main.view.fragment.FleetFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="5sp"
        android:paddingEnd="5sp"
        android:orientation="vertical"
        android:paddingBottom="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dip"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:background="@android:color/transparent"
            app:contentInsetStartWithNavigation="0dp"
            app:titleTextAppearance="@style/ActionBar.toolbarTheme"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="0dip"
                android:layout_marginEnd="0dip"
                android:layout_marginBottom="0dip"
                android:orientation="horizontal"
                android:paddingLeft="0dp"
                android:paddingTop="0dp"
                android:paddingRight="0dp"
                android:paddingBottom="0dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="4"
                    android:gravity="left"
                    android:layout_gravity="center_vertical"
                    android:orientation="horizontal"
                    tools:ignore="Suspicious0dp">
                    <TextView
                        android:visibility="visible"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_gravity="center_vertical"
                        android:fontFamily="@font/roboto_regular"
                        android:textStyle="bold"
                        android:textSize="26dp"
                        android:textColor="@color/white"
                        android:text="Units"
                        android:shadowColor="@color/black"
                        android:shadowDx="1"
                        android:shadowDy="1"
                        android:shadowRadius="2"
                        android:drawableLeft="@drawable/ic_excavator"
                        android:drawablePadding="5dp"/>

                    <androidx.appcompat.widget.SearchView
                        android:visibility="visible"
                        android:id="@+id/et_search"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:background="@android:color/transparent"
                        android:gravity="left"
                        android:textSize="18dp"
                        android:drawableRight="@drawable/ic_search"
                        android:drawablePadding="10dp"
                        android:layout_marginEnd="10dp"
                        android:layout_gravity="right"
                        android:hint="Search"
                        android:layoutDirection="rtl"
                        app:queryBackground="@drawable/bg_rounded_white"
                        app:iconifiedByDefault="true"
                        app:searchIcon="@drawable/ic_search_white"
                        app:tint="@color/red" />
                </LinearLayout>

                <LinearLayout
                    android:visibility="gone"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:layout_gravity="left|center_vertical"
                    android:orientation="horizontal"
                    tools:ignore="Suspicious0dp">
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:src="@drawable/icon_share"
                        android:layout_gravity="center"
                        android:id="@+id/iv_share"
                        android:contentDescription="notification" />
                </LinearLayout>

                <LinearLayout
                    android:visibility="gone"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:layout_gravity="left|center_vertical"
                    android:orientation="horizontal"
                    tools:ignore="Suspicious0dp">
                    <ImageView
                        android:id="@+id/iv_settings"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:src="@drawable/b_setting"
                        android:layout_marginEnd="0dp"
                        android:layout_gravity="center"
                        app:tint="@color/black"
                        tools:ignore="UseAppTint" />
                </LinearLayout>

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

        <RelativeLayout
            android:id="@+id/rl_card"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:paddingLeft="15dp"
            android:paddingEnd="15dp"
            android:clipChildren="false">

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="0dip"
                android:layout_marginEnd="0dip"
                android:layout_marginBottom="0dip"
                android:orientation="vertical"
                android:paddingLeft="0dp"
                android:paddingTop="0dp"
                android:paddingRight="0dp"
                android:paddingBottom="0dp">

                <!-- start search -->
                <LinearLayout
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded_fill_grey"
                    android:layout_marginStart="0dip"
                    android:layout_marginEnd="0dip"
                    android:layout_marginBottom="0dip"
                    android:orientation="horizontal"
                    android:paddingLeft="0dp"
                    android:paddingTop="0dp"
                    android:paddingRight="0dp"
                    android:paddingBottom="0dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:layout_gravity="left|center_vertical"
                        android:orientation="horizontal"
                        tools:ignore="Suspicious0dp">

                        <androidx.appcompat.widget.SearchView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            android:paddingStart="5dp"
                            android:paddingEnd="5dp"
                            android:background="@android:color/transparent"
                            android:gravity="left"
                            android:textSize="18dp"
                            android:drawableRight="@drawable/ic_search"
                            android:drawablePadding="10dp"
                            android:layout_marginEnd="0dp"
                            android:layout_gravity="right"
                            android:hint="Search"
                            android:layoutDirection="rtl"
                            app:queryBackground="@null"
                            app:iconifiedByDefault="false"
                            app:searchIcon="@drawable/ic_search"
                            app:tint="@color/black" />

                    </LinearLayout>

                </LinearLayout>
                <!-- end search -->

                <!-- start tasks selected -->
                <LinearLayout
                    android:visibility="visible"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded_grey"
                    android:layout_marginStart="0dip"
                    android:layout_marginEnd="0dip"
                    android:layout_marginTop="0dip"
                    android:layout_marginBottom="0dip"
                    android:orientation="horizontal"
                    android:paddingLeft="0dp"
                    android:paddingTop="10dp"
                    android:paddingRight="0dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="right"
                        android:layout_gravity="left|center_vertical"
                        android:orientation="horizontal"
                        tools:ignore="Suspicious0dp">
                        <TextView
                            android:id="@+id/tv_filter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:paddingStart="15dp"
                            android:paddingEnd="15dp"
                            android:gravity="left"
                            android:textSize="18dp"
                            android:drawableRight="@drawable/icon_down_small"
                            android:drawablePadding="10dp"
                            android:layout_marginEnd="0dp"
                            android:layout_gravity="right"
                            android:text="All Units"
                            app:tint="@color/grey"
                            tools:ignore="UseAppTint" />
                    </LinearLayout>

                </LinearLayout>
                <!-- end contact selected -->

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center">

                    <androidx.recyclerview.widget.RecyclerView
                        android:visibility="gone"
                        android:id="@+id/recycler_view_product_list"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="0dp"
                        android:layout_marginBottom="0dp">

                    </androidx.recyclerview.widget.RecyclerView>

                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:visibility="visible"
                        android:id="@+id/shimmer_view_container"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:layout_marginTop="0dp"
                        android:layout_marginBottom="0dip"
                        android:orientation="vertical"
                        shimmer:duration="800">

                        <!-- Adding 7 rows of placeholders -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <include layout="@layout/layout_list_product" />
                            <include layout="@layout/layout_list_product" />
                            <include layout="@layout/layout_list_product" />
                            <include layout="@layout/layout_list_product" />
                            <include layout="@layout/layout_list_product" />
                            <include layout="@layout/layout_list_product" />
                            <include layout="@layout/layout_list_product" />
                        </LinearLayout>

                    </com.facebook.shimmer.ShimmerFrameLayout>

                    <LinearLayout
                        android:visibility="gone"
                        android:id="@+id/ll_empty"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Data is Empty"/>
                    </LinearLayout>

                    <!-- start floating adding -->
                    <LinearLayout
                        android:visibility="gone"
                        android:id="@+id/ll_add_fleet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentRight="true"
                        android:gravity="right"
                        android:layout_gravity="center|bottom">
                        <com.google.android.material.floatingactionbutton.FloatingActionButton
                            android:id="@+id/add_unit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_plus_white"
                            app:backgroundTint="@color/blue"
                            app:fabCustomSize="60dp"
                            app:maxImageSize="25dp"
                            app:tint="@color/white"
                            app:elevation="6dp"
                            app:borderWidth="0dp"
                            android:contentDescription="Add Unit" />
                    </LinearLayout>
                    <!-- end floating adding -->

                </RelativeLayout>

            </LinearLayout>

        </RelativeLayout>

    </LinearLayout>

    <include
        android:id="@+id/llProgressBar"
        android:visibility="gone"
        layout="@layout/layout_progress"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>